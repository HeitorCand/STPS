# ── Dependencies ────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Rust / Anchor build artifacts ───────────────────────────
target/
# but keep generated IDL and TypeScript types
!target/idl/
!target/types/

# ── Next.js ─────────────────────────────────────────────────
.next/
out/

# ── TypeScript / JS build output ────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment files (NEVER commit secrets) ────────────────
.env
.env.local
.env.bak
.env.*.local
# allow example files
!.env.example
!**/.env.example

# ── Solana keypairs (NEVER commit) ──────────────────────────
# Block ALL json by default then allow known-safe files
*.json
!package.json
!package-lock.json
!tsconfig.json
!tsconfig*.json
!turbo.json
!Anchor.toml
!target/idl/*.json
!target/types/*.json
!documentation/content/docs/**/meta.json

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Turbo cache ──────────────────────────────────────────────
.turbo/

# ── Anchor CLI cache ─────────────────────────────────────────
.anchor/

# ── Test / coverage ──────────────────────────────────────────
coverage/
.nyc_output/


.codex
.agents
DESIGN.md
PRODUCT.md
documentation/.source/
copilot-instructions.md
docs
