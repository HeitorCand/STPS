{
  "name": "stps",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:indexer": "pnpm --filter @stps/indexer dev",
    "dev:scoring": "pnpm --filter @stps/scoring dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
