# ============================================================================
# Scoring Engine (@stps/scoring) — Variáveis de Ambiente
# ============================================================================

# Porta HTTP do servidor Express
# IMPORTANTE: deve ser 3001 — é o valor que o Indexer usa em SCORING_ENGINE_URL.
PORT=3001

# ----------------------------------------------------------------------------
# Solana / Anchor
# ----------------------------------------------------------------------------

# URL do nó RPC Solana (Helius recomendado para devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Program ID do contrato STPS (igual em devnet e localnet)
ANCHOR_PROGRAM_ID=FuAM2peBxYQgr4Sspd43FkYK7vuCZ5rTPxZYCnCSeCZk

# Keypair da Scoring Authority — JSON array de bytes
# NUNCA commitar. Ex: [12,34,56,...]
SCORING_AUTHORITY_KEYPAIR=

# Se 'true', desativa as chamadas on-chain (útil para dev sem programa deployado).
# Em produção, deixar 'false'.
DISABLE_ON_CHAIN=false

# ----------------------------------------------------------------------------
# DeFiLlama (Layer 2)
# ----------------------------------------------------------------------------

DEFI_LLAMA_BASE_URL=https://api.llama.fi

# TTL do cache em segundos
DEFI_LLAMA_CACHE_TTL_SECONDS=60

# ----------------------------------------------------------------------------
# Configuração de protocolos monitorados (catálogo MVP)
# ----------------------------------------------------------------------------

# Mapa protocol_address → defi-llama slug (JSON inline)
# Ex: {"dRiftyHA39MWEi3m9aunc5MzRF1JYuBsbn6VPcn33UH":"drift"}
PROTOCOL_DEFILLAMA_MAP={"dRiftyHA39MWEi3m9aunc5MzRF1JYuBsbn6VPcn33UH":"drift"}

# Mapa protocol_address → admin keys (JSON inline, array de pubkeys)
# Usado pela Layer 3 para localizar nonce accounts.
PROTOCOL_ADMIN_KEYS_MAP={}

# ----------------------------------------------------------------------------
# Score inicial atribuído ao registar um protocolo novo
# ----------------------------------------------------------------------------
DEFAULT_INITIAL_SCORE=85
